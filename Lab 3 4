import tkinter as tk
from tkinter import ttk, messagebox
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
from collections import deque
import os
from datetime import datetime


class BaseStationSimulator:
    def __init__(self, root):
        self.root = root
        self.root.title("Stacja Bazowa - Symulator M/M/S/S")
        self.root.geometry("1600x900")

        self.num_channels = 10
        self.queue_length = 10
        self.lambda_rate = 1.0
        self.avg_call_duration = 20
        self.std_dev = 5
        self.min_duration = 10
        self.max_duration = 30
        self.simulation_time = 30

        # Listy zgodne z zadaniem
        self.lambda_list = []  # Lista λi (stóp przybycia)
        self.mu_list = []  # Lista μi (długości rozmów) - pary z λi
        self.pairs = []  # Lista par (λi, μi)

        self.channels = [None] * self.num_channels
        self.queue = deque(maxlen=self.queue_length)
        self.served_calls = 0
        self.blocked_calls = 0
        self.handoff_calls = 0

        self.rho_history = []
        self.q_history = []
        self.w_history = []
        self.time_history = []

        self.simulating = False
        self.paused = False
        self.current_time = 0
        self.call_counter = 0
        self.current_k = 0

        self.results_file = ""
        self.setup_ui()
        self.setup_plots()

    def init_results_file(self):
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        self.results_file = f"wyniki_symulacji_{timestamp}.txt"

        with open(self.results_file, 'w', encoding='utf-8') as f:
            f.write("PARAMETRY SYMULACJI:\n")
            f.write(f"Liczba kanałów: {self.num_channels}\n")
            f.write(f"Długość kolejki: {self.queue_length}\n")
            f.write(f"Lambda (natężenie): {self.lambda_rate}\n")
            f.write(f"Średnia długość rozmowy: {self.avg_call_duration}\n")
            f.write(f"Odchylenie standardowe: {self.std_dev}\n")
            f.write(f"Min czas: {self.min_duration}\n")
            f.write(f"Max czas: {self.max_duration}\n")
            f.write(f"Czas symulacji: {self.simulation_time}\n\n")

            f.write("WYNIKI:\n")
            f.write(f"{'Czas':>6} {'Rho':>8} {'Q':>8} {'W':>8} ")
            f.write(f"{'Kanaly':>8} {'Lambda':>8} {'Srednia':>10} ")
            f.write(f"{'Obsluz':>8} {'Zablok':>8}\n")
            f.write("-" * 80 + "\n")

    def save_results(self):
        if self.time_history:
            with open(self.results_file, 'a', encoding='utf-8') as f:
                f.write(f"{self.current_time:6.1f} "
                        f"{self.rho_history[-1]:8.4f} "
                        f"{self.q_history[-1]:8.2f} "
                        f"{self.w_history[-1]:8.2f} "
                        f"{self.num_channels:8d} "
                        f"{self.lambda_rate:8.2f} "
                        f"{self.avg_call_duration:10.2f} "
                        f"{self.served_calls:8d} "
                        f"{self.blocked_calls:8d}\n")

    def generate_pairs(self):
        """Krok 1 i 2: Generowanie par (λi, μi)"""
        self.pairs = []
        total_lambda = 0
        call_id = 0

        # Generuj aż suma λi > czas symulacji
        while total_lambda <= self.simulation_time:
            # λi z rozkładu Poissona (wykładniczy dla czasu między przyjściami)
            lambda_i = np.random.exponential(1.0 / self.lambda_rate)

            # μi z rozkładu Gaussa z ograniczeniami
            mu_i = np.random.normal(self.avg_call_duration, self.std_dev)
            mu_i = max(self.min_duration, min(self.max_duration, mu_i))

            self.pairs.append({
                'id': call_id,
                'lambda': lambda_i,
                'mu': mu_i,
                'arrival_time': total_lambda,  # skumulowany czas
                'processed': False
            })

            total_lambda += lambda_i
            call_id += 1

        return self.pairs

    def get_next_k_elements(self):
        """Krok 3a: Pobierz k elementów gdzie Σλi < 1 i Σλi ≥ 1"""
        if not self.pairs:
            return []

        k_elements = []
        sum_lambda = 0
        index = 0

        # Szukaj pierwszego nieprzetworzonego elementu
        while index < len(self.pairs) and self.pairs[index]['processed']:
            index += 1

        if index >= len(self.pairs):
            return []

        # Zbieraj elementy aż Σλi ≥ 1
        while index < len(self.pairs) and sum_lambda < 1:
            pair = self.pairs[index]
            if not pair['processed']:
                sum_lambda += pair['lambda']
                k_elements.append(pair)
            index += 1

        # Sprawdź warunek Σλi ≥ 1
        if sum_lambda >= 1:
            return k_elements
        else:
            return []  # Nie ma wystarczającej liczby elementów

    def setup_ui(self):
        main_frame = ttk.Frame(self.root, padding="10")
        main_frame.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S))

        left_column = ttk.Frame(main_frame)
        left_column.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S), padx=5)

        right_column = ttk.Frame(main_frame)
        right_column.grid(row=0, column=1, sticky=(tk.W, tk.E, tk.N, tk.S), padx=5)

        params_frame = ttk.LabelFrame(left_column, text="Parametry", padding="10")
        params_frame.grid(row=0, column=0, sticky=(tk.W, tk.E), pady=5)

        params = [
            ("Liczba kanałów:", "num_channels", 10),
            ("Długość kolejki:", "queue_length", 10),
            ("Natężenie ruchu [lambda]:", "lambda_rate", 1.0),
            ("Średnia długość rozmowy [s]:", "avg_call_duration", 20),
            ("Odchylenie standardowe:", "std_dev", 5),
            ("Minimalny czas połączenia [s]:", "min_duration", 10),
            ("Maksymalny czas połączenia [s]:", "max_duration", 30),
            ("Czas symulacji [s]:", "simulation_time", 30)
        ]

        self.param_vars = {}
        for i, (label, param, default) in enumerate(params):
            ttk.Label(params_frame, text=label).grid(row=i, column=0, sticky=tk.W, pady=2)
            var = tk.StringVar(value=str(default))
            self.param_vars[param] = var
            ttk.Entry(params_frame, textvariable=var, width=15).grid(row=i, column=1, padx=5, pady=2)

        button_frame = ttk.Frame(params_frame)
        button_frame.grid(row=len(params), column=0, columnspan=2, pady=10)

        ttk.Button(button_frame, text="START", command=self.start_simulation).pack(side=tk.LEFT, padx=2)
        ttk.Button(button_frame, text="Pause", command=self.pause_simulation).pack(side=tk.LEFT, padx=2)
        ttk.Button(button_frame, text="Play", command=self.resume_simulation).pack(side=tk.LEFT, padx=2)
        ttk.Button(button_frame, text="Pokaż wyniki", command=self.show_results).pack(side=tk.LEFT, padx=2)
        ttk.Button(button_frame, text="Otwórz plik", command=self.open_results_file).pack(side=tk.LEFT, padx=2)

        results_frame = ttk.LabelFrame(left_column, text="Wyniki", padding="10")
        results_frame.grid(row=1, column=0, sticky=(tk.W, tk.E), pady=5)

        self.stats_labels = {}
        stats_items = [
            ("Obsłużone:", "served", "0"),
            ("Zablokowane:", "blocked", "0"),
            ("Przeniesione:", "handoff", "0"),
            ("Kolejka:", "queue", "0/10"),
            ("Śr. długość kolejki (Q):", "avg_q", "0.00"),
            ("Śr. czas oczekiwania (W):", "avg_w", "0.00"),
            ("Intensywność (ρ):", "rho", "0.00"),
            ("Aktualne k:", "current_k", "0")
        ]

        for i, (label, key, default) in enumerate(stats_items):
            ttk.Label(results_frame, text=label).grid(row=i, column=0, sticky=tk.W, pady=2)
            var = tk.StringVar(value=default)
            self.stats_labels[key] = var
            ttk.Label(results_frame, textvariable=var, font=('Arial', 10, 'bold')).grid(
                row=i, column=1, sticky=tk.W, padx=5)

        self.file_label = ttk.Label(results_frame, text=f"Plik: {self.results_file}",
                                    foreground='blue', wraplength=200)
        self.file_label.grid(row=len(stats_items), column=0, columnspan=2, pady=10)

        channels_frame = ttk.LabelFrame(left_column, text="Kanały - stan bieżący", padding="10")
        channels_frame.grid(row=2, column=0, sticky=(tk.W, tk.E, tk.N, tk.S), pady=5)

        channels_display = ttk.Frame(channels_frame)
        channels_display.pack(fill=tk.BOTH, expand=True)

        ttk.Label(channels_display, text="Kanał", font=('Arial', 10, 'bold')).grid(row=0, column=0, padx=5, pady=2)
        ttk.Label(channels_display, text="Status", font=('Arial', 10, 'bold')).grid(row=0, column=1, padx=5, pady=2)
        ttk.Label(channels_display, text="Pozostało", font=('Arial', 10, 'bold')).grid(row=0, column=2, padx=5, pady=2)

        self.channel_status_labels = []
        self.channel_time_labels = []

        for i in range(self.num_channels):
            ttk.Label(channels_display, text=f"Kanał {i + 1}:").grid(row=i + 1, column=0, padx=5, pady=2, sticky=tk.W)

            status_label = ttk.Label(channels_display, text="wolny", foreground='green')
            status_label.grid(row=i + 1, column=1, padx=5, pady=2, sticky=tk.W)
            self.channel_status_labels.append(status_label)

            time_label = ttk.Label(channels_display, text="-")
            time_label.grid(row=i + 1, column=2, padx=5, pady=2, sticky=tk.W)
            self.channel_time_labels.append(time_label)

        ttk.Label(channels_display, text="-" * 40).grid(row=self.num_channels + 1, column=0, columnspan=3, pady=10)
        ttk.Label(channels_display, text="Kolejka:", font=('Arial', 10, 'bold')).grid(row=self.num_channels + 2,
                                                                                      column=0, padx=5, pady=2,
                                                                                      sticky=tk.W)
        self.queue_label = ttk.Label(channels_display, text="0/10")
        self.queue_label.grid(row=self.num_channels + 2, column=1, columnspan=2, padx=5, pady=2, sticky=tk.W)

        plots_frame = ttk.LabelFrame(right_column, text="Wykresy", padding="10")
        plots_frame.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S), pady=5)

        self.fig, (self.ax1, self.ax2, self.ax3) = plt.subplots(3, 1, figsize=(7, 9))
        self.fig.subplots_adjust(hspace=0.4)
        self.canvas = FigureCanvasTkAgg(self.fig, master=plots_frame)
        self.canvas.get_tk_widget().pack(fill=tk.BOTH, expand=True)

    def setup_plots(self):
        self.ax1.set_ylabel('ρ')
        self.ax1.set_xlabel('Czas [s]')
        self.ax1.set_title('Intensywność ruchu')
        self.ax1.grid(True)

        self.ax2.set_ylabel('Q')
        self.ax2.set_xlabel('Czas [s]')
        self.ax2.set_title('Długość kolejki')
        self.ax2.grid(True)

        self.ax3.set_ylabel('W [s]')
        self.ax3.set_xlabel('Czas [s]')
        self.ax3.set_title('Średni czas oczekiwania')
        self.ax3.grid(True)

        self.fig.tight_layout()

    def update_channels_display(self):
        for i, channel in enumerate(self.channels):
            if channel:
                self.channel_status_labels[i].config(text="zajęty", foreground='red')
                self.channel_time_labels[i].config(text=f"{channel['remaining']:.1f}s")
            else:
                self.channel_status_labels[i].config(text="wolny", foreground='green')
                self.channel_time_labels[i].config(text="-")

        self.queue_label.config(text=f"{len(self.queue)}/{self.queue_length}")
        self.stats_labels['current_k'].set(str(self.current_k))

        self.root.update_idletasks()

    def update_stats(self):
        self.stats_labels['served'].set(str(self.served_calls))
        self.stats_labels['blocked'].set(str(self.blocked_calls))
        self.stats_labels['handoff'].set(str(self.handoff_calls))
        self.stats_labels['queue'].set(f"{len(self.queue)}/{self.queue_length}")

        if self.time_history:
            avg_q = np.mean(self.q_history[-10:]) if self.q_history else 0
            avg_w = np.mean(self.w_history[-10:]) if self.w_history else 0
            rho = np.mean(self.rho_history[-10:]) if self.rho_history else 0
            self.stats_labels['avg_q'].set(f"{avg_q:.2f}")
            self.stats_labels['avg_w'].set(f"{avg_w:.2f}")
            self.stats_labels['rho'].set(f"{rho:.2f}")

    def update_plots(self):
        if not self.time_history:
            return

        self.ax1.clear()
        self.ax2.clear()
        self.ax3.clear()

        self.ax1.plot(self.time_history, self.rho_history, 'b-', linewidth=2)
        self.ax1.set_ylabel('ρ')
        self.ax1.set_xlabel('Czas [s]')
        self.ax1.set_title('Intensywność ruchu')
        self.ax1.grid(True)

        self.ax2.plot(self.time_history, self.q_history, 'r-', linewidth=2)
        self.ax2.set_ylabel('Q')
        self.ax2.set_xlabel('Czas [s]')
        self.ax2.set_title('Długość kolejki')
        self.ax2.grid(True)

        self.ax3.plot(self.time_history, self.w_history, 'g-', linewidth=2)
        self.ax3.set_xlabel('Czas [s]')
        self.ax3.set_ylabel('W [s]')
        self.ax3.set_title('Średni czas oczekiwania')
        self.ax3.grid(True)

        self.fig.tight_layout()
        self.canvas.draw()

    def simulation_step(self):
        if not self.simulating or self.paused:
            return

        self.current_time += 1

        # Krok 3a: Pobierz k elementów
        k_elements = self.get_next_k_elements()
        self.current_k = len(k_elements)

        # Krok 3b: Umieść k elementów w kanałach
        for pair in k_elements:
            # Szukaj wolnego kanału
            assigned = False
            for i, channel in enumerate(self.channels):
                if channel is None:
                    self.channels[i] = {
                        'id': pair['id'],
                        'duration': pair['mu'],
                        'remaining': pair['mu'],
                        'arrival_time': self.current_time
                    }
                    assigned = True
                    pair['processed'] = True
                    break

            if not assigned:
                # Wszystkie kanały zajęte - dodaj do kolejki
                if len(self.queue) < self.queue_length:
                    self.queue.append({
                        'id': pair['id'],
                        'duration': pair['mu'],
                        'remaining': pair['mu'],
                        'arrival_time': self.current_time
                    })
                    pair['processed'] = True
                else:
                    self.blocked_calls += 1
                    pair['processed'] = True  # Mimo blokady, element jest przetworzony

        # Aktualizuj pozostały czas w kanałach
        for i, channel in enumerate(self.channels):
            if channel:
                channel['remaining'] -= 1
                if channel['remaining'] <= 0:
                    self.channels[i] = None
                    self.served_calls += 1

                    if self.queue:
                        next_call = self.queue.popleft()
                        self.channels[i] = next_call

        # Oblicz statystyki
        busy_channels = sum(1 for ch in self.channels if ch is not None)
        rho = busy_channels / self.num_channels if self.num_channels > 0 else 0
        q_length = len(self.queue)

        wait_times = []
        for ch in self.channels:
            if ch and 'arrival_time' in ch:
                wait_times.append(self.current_time - ch['arrival_time'])
        for q_item in self.queue:
            if 'arrival_time' in q_item:
                wait_times.append(self.current_time - q_item['arrival_time'])

        w = np.mean(wait_times) if wait_times else 0

        self.time_history.append(self.current_time)
        self.rho_history.append(rho)
        self.q_history.append(q_length)
        self.w_history.append(w)

        self.save_results()
        self.update_channels_display()
        self.update_stats()
        self.update_plots()

        if self.current_time < self.simulation_time:
            self.root.after(100, self.simulation_step)
        else:
            self.simulating = False

    def start_simulation(self):
        try:
            self.num_channels = int(self.param_vars['num_channels'].get())
            self.queue_length = int(self.param_vars['queue_length'].get())
            self.lambda_rate = float(self.param_vars['lambda_rate'].get())
            self.avg_call_duration = float(self.param_vars['avg_call_duration'].get())
            self.std_dev = float(self.param_vars['std_dev'].get())
            self.min_duration = float(self.param_vars['min_duration'].get())
            self.max_duration = float(self.param_vars['max_duration'].get())
            self.simulation_time = float(self.param_vars['simulation_time'].get())
        except ValueError as e:
            messagebox.showerror("Błąd", f"Nieprawidłowe parametry: {e}")
            return

        # Krok 1 i 2: Generuj pary (λi, μi)
        self.generate_pairs()

        self.init_results_file()
        self.file_label.config(text=f"Plik: {self.results_file}")

        self.channels = [None] * self.num_channels
        self.queue = deque(maxlen=self.queue_length)
        self.served_calls = 0
        self.blocked_calls = 0
        self.handoff_calls = 0
        self.current_time = 0
        self.time_history = []
        self.rho_history = []
        self.q_history = []
        self.w_history = []

        self.simulating = True
        self.paused = False
        self.simulation_step()

    def pause_simulation(self):
        self.paused = True

    def resume_simulation(self):
        if self.paused:
            self.paused = False
            self.simulation_step()

    def open_results_file(self):
        if os.path.exists(self.results_file):
            os.startfile(os.path.dirname(self.results_file) or ".")

    def show_results(self):
        if not os.path.exists(self.results_file):
            messagebox.showinfo("Info", "Brak wyników. Uruchom symulację najpierw.")
            return

        results_window = tk.Toplevel(self.root)
        results_window.title("Wyniki symulacji")
        results_window.geometry("900x600")

        text_frame = ttk.Frame(results_window)
        text_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)

        scrollbar = ttk.Scrollbar(text_frame)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)

        text_widget = tk.Text(text_frame, wrap=tk.NONE, yscrollcommand=scrollbar.set,
                              font=('Courier New', 10))
        text_widget.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)

        scrollbar.config(command=text_widget.yview)

        with open(self.results_file, 'r', encoding='utf-8') as f:
            text_widget.insert('1.0', f.read())

        text_widget.config(state=tk.DISABLED)

        ttk.Button(results_window, text="Otwórz plik",
                   command=self.open_results_file).pack(pady=5)


if __name__ == "__main__":
    root = tk.Tk()
    app = BaseStationSimulator(root)
    root.mainloop()
